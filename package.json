{
  "name": "ooxml-excel-preview",
  "version": "1.1.0",
  "description": "High-fidelity OOXML (.xlsx) preview — canvas renderer, read-only. Framework-agnostic core with Vue 3 and React shells.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "keywords": [
    "vue",
    "vue3",
    "react",
    "excel",
    "xlsx",
    "ooxml",
    "spreadsheet",
    "preview",
    "viewer",
    "canvas",
    "exceljs"
  ],
  "homepage": "https://github.com/your-org/ooxml-excel-preview#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/ooxml-excel-preview.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/ooxml-excel-preview/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:demo": "vite build --mode demo",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "vue-tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "echarts": "^5.5.0",
    "exceljs": "^4.4.0",
    "hyperformula": "^3.0.0",
    "jspdf": "^2.5.0 || ^3.0.0 || ^4.0.0",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "echarts": {
      "optional": true
    },
    "hyperformula": {
      "optional": true
    },
    "jspdf": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@playwright/test": "1.58.0",
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.30",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "echarts": "^5.5.1",
    "exceljs": "^4.4.0",
    "hyperformula": "^3.3.0",
    "jspdf": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.1.8",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  }
}
